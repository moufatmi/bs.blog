---
import Layout from '../layouts/Layout.astro';
import ProgramCard from '../components/ProgramCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const voyagePrograms = await getCollection('voyages');

const destinations = [
  { name: "Turquie", count: 3 },
  { name: "Espagne", count: 2 },
  { name: "Maroc", count: 4 },
  { name: "Jordanie", count: 2 },
  { name: "Egypte", count: 3 },
  { name: "Ouzbékistan", count: 1 }
];
---

<Layout title="Voyages Organisés - Beauséjour Voyage" description="Découvrez nos voyages organisés vers les destinations culturelles et historiques du monde musulman. Circuits accompagnés avec guides experts.">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-brand-teal via-brand-cyan to-gold text-white overflow-hidden">
    <div class="absolute inset-0 bg-black opacity-40"></div>
    <div class="absolute inset-0">
      <img 
        src="https://images.pexels.com/photos/2387870/pexels-photo-2387870.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&fit=crop" 
        alt="Istanbul Turkey" 
        class="w-full h-full object-cover"
      />
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="max-w-4xl">
        <h1 class="text-4xl lg:text-6xl font-bold mb-6 leading-tight">
          Voyages Organisés
          <span class="block text-gold">Culturels & Historiques</span>
        </h1>
        
        <p class="text-xl lg:text-2xl mb-8 text-gray-200 leading-relaxed">
          Partez à la découverte des plus belles destinations du monde musulman. 
          Circuits accompagnés avec guides experts pour une immersion culturelle authentique.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="#programmes" 
            class="bg-gold hover:bg-yellow-600 text-brand-teal px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 transform hover:scale-105 text-center"
          >
            Voir tous nos voyages
          </a>
          <a 
            href="/contact" 
            class="border-2 border-white hover:bg-white hover:text-brand-teal text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-300 text-center"
          >
            Demander un devis
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Destinations Filter -->
  <section class="py-8 bg-white border-b dark:bg-gray-900 dark:border-gray-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-4">
        <button class="px-6 py-2 rounded-full bg-gold text-white font-medium">
          Toutes destinations
        </button>
        {destinations.map(dest => (
          <button class="px-6 py-2 rounded-full border-2 border-gold text-gold hover:bg-gold hover:text-white transition-all duration-200 font-medium dark:text-yellow-400 dark:border-yellow-400 dark:hover:bg-yellow-400 dark:hover:text-gray-900">
            {dest.name} ({dest.count})
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Programs Section -->
  <section id="programmes" class="py-16 bg-warm-beige dark:bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-brand-teal mb-4 dark:text-cyan-400">
          Nos Destinations Phares
        </h2>
        <p class="text-xl text-gray-600 max-w-4xl mx-auto dark:text-gray-300">
          Des circuits soigneusement élaborés pour vous faire découvrir la richesse historique, 
          culturelle et architecturale des civilisations islamiques à travers le monde.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {voyagePrograms.map((program) => (
          <ProgramCard {...program.data} />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-brand-teal mb-4 dark:text-cyan-400">
          L'Excellence de nos Voyages Organisés
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-2xl shadow-lg text-center dark:bg-gray-800">
          <div class="bg-brand-teal/10 text-brand-teal rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4 dark:bg-cyan-400/10 dark:text-cyan-400">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-2 dark:text-gray-100">Guides Experts</h3>
          <p class="text-gray-600 dark:text-gray-300">Nos guides francophones sont des experts passionnés de l'histoire et de la culture des régions visitées.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-lg text-center dark:bg-gray-800">
          <div class="bg-brand-teal/10 text-brand-teal rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4 dark:bg-cyan-400/10 dark:text-cyan-400">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 4h5m-5 4h5"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-2 dark:text-gray-100">Hôtels de Charme</h3>
          <p class="text-gray-600 dark:text-gray-300">Nous sélectionnons des hébergements de qualité alliant confort moderne et authenticité locale.</p>
        </div>
        <div class="bg-white p-6 rounded-2xl shadow-lg text-center dark:bg-gray-800">
          <div class="bg-brand-teal/10 text-brand-teal rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4 dark:bg-cyan-400/10 dark:text-cyan-400">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-2 dark:text-gray-100">Itinéraires Optimisés</h3>
          <p class="text-gray-600 dark:text-gray-300">Nos circuits sont conçus pour vous offrir une expérience riche et fluide, sans perte de temps.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-r from-brand-teal to-brand-cyan text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold mb-6">
        Prêt pour une Aventure Culturelle Inoubliable ?
      </h2>
      <p class="text-xl mb-8 text-gray-200">
        Contactez nos experts voyage pour créer votre circuit sur mesure ou réserver l'un de nos programmes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/contact" 
          class="bg-black hover:bg-black-600 text-brand-teal px-8 py-4 rounded-lg font-semibold text-lg transition-colors duration-200"
        >
          Demander un devis sur mesure
        </a>
        <a 
          href="tel:+33123456789" 
          class="border-2 border-white hover:bg-white hover:text-brand-teal text-white px-8 py-4 rounded-lg font-semibold text-lg transition-all duration-200"
        >
          Parler à un conseiller
        </a>
      </div>
    </div>
  </section>
</Layout>