---
import Layout from '../../layouts/Layout.astro';
import ProgramCard from '../../components/ProgramCard.astro';
import { getCollection } from 'astro:content';
import Hero from '../../components/Hero.astro';
import heroImage from '../../assets/pics/hajj-omra-hero.png';

const omraPrograms = await getCollection('omra');
---

<Layout 
  title="Agence de Voyage Omra Oujda | Beauséjour Voyage" 
  description=". Découvrez nos offres d'Omra Ramadan 2026, nos tarifs compétitifs pour le Maroc, et nos vols directs depuis l'Aéroport Oujda Angads."
>
  <Hero
    img={heroImage}
    title=""
    desc="Votre pèlerinage spirituel en toute sérénité avec Beauséjour Voyage. Vols directs, hôtels de choix et accompagnement professionnel de A à Z."
  />

  <!-- Keyword-driven Intro Section -->
  <section class="py-12 bg-warm-beige dark:bg-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-xl p-8 lg:p-12">
        <div class="text-center max-w-3xl mx-auto mb-10">
          <h2 class="text-3xl font-extrabold text-brand-teal dark:text-cyan-400 mb-4">
            Votre agence de confiance pour l'Omra et le Hajj à Oujda
          </h2>
          <div class="w-16 h-1 bg-gold mx-auto mb-6"></div>
          <p class="text-lg text-gray-600 dark:text-gray-300">
            Forte de plusieurs années d'expérience, l'agence <strong>Beauséjour Voyage</strong> est reconnue comme la référence locale pour l'organisation de l'Omra et du Hajj dans l'Oriental. Nous veillons aux moindres détails pour que votre voyage de foi soit une expérience inoubliable et confortable.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="space-y-3">
            <div class="text-gold dark:text-yellow-400 font-bold text-lg flex items-center">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"></path></svg>
              Omra Ramadan Oujda
            </div>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
              Nous organisons des départs spéciaux durant tout le mois sacré de Ramadan. Vivez les moments intenses des dix derniers jours dans le Haram avec des formules parfaitement adaptées.
            </p>
          </div>

          <div class="space-y-3">
            <div class="text-gold dark:text-yellow-400 font-bold text-lg flex items-center">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
              Prix Omra 2026 Maroc
            </div>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
              Nous négocions directement auprès des compagnies aériennes et des chaînes hôtelières pour vous offrir les tarifs d'Omra 2026 les plus compétitifs du Maroc, sans compromis sur la qualité.
            </p>
          </div>

          <div class="space-y-3">
            <div class="text-gold dark:text-yellow-400 font-bold text-lg flex items-center">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
              Vols directs Omra depuis Aéroport Oujda Angads
            </div>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
              Un gain de confort inestimable : tous nos programmes clés en main incluent des vols directs aller-retour au départ de l'aéroport d'Oujda en partenariat avec Royal Air Maroc et Saudi Airlines.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs Grid Section -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold text-brand-teal mb-4 dark:text-cyan-400">
          Nos Formules Omra 2026
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto dark:text-gray-300">
          Sélectionnez l'offre qui correspond le mieux à votre budget et à vos besoins spirituels.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {omraPrograms.map((program) => (
          <ProgramCard 
            title={program.data.title}
            description={program.data.description}
            image={program.data.image}
            price={program.data.price}
            duration={program.data.duration}
            features={program.data.features}
            type="omra"
            slug={program.slug}
            pdfUrl={program.data.pdfUrl}
            availabilityNote={program.data.availabilityNote}
          />
        ))}
        {omraPrograms.length === 0 && (
          <div class="col-span-full text-center py-20">
            <p class="text-2xl text-gray-500 font-medium dark:text-gray-400">Aucun programme d'Omra disponible pour le moment.</p>
            <p class="mt-2 text-gray-400">Contactez-nous directement pour connaître nos prochains départs.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Information Section (FAQ/Benefits) -->
  <section class="py-16 bg-gradient-to-r from-brand-teal to-brand-cyan text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold mb-4">
          Pourquoi faire confiance à notre agence pour l'Omra ?
        </h2>
        <p class="text-xl text-gray-200 max-w-3xl mx-auto">
          Nous mettons tout en œuvre pour faire de votre séjour spirituel une réussite absolue.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 text-gray-900">
        <div class="bg-white/95 dark:bg-gray-800 dark:text-white p-8 rounded-2xl shadow-lg">
          <h3 class="font-bold text-xl mb-3 text-brand-teal dark:text-cyan-400">Accompagnement Spirituel</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Des guides expérimentés vous accompagnent durant les rites de l'Omra, en vous dispensant des cours théoriques et pratiques à La Mecque et Médine.
          </p>
        </div>

        <div class="bg-white/95 dark:bg-gray-800 dark:text-white p-8 rounded-2xl shadow-lg">
          <h3 class="font-bold text-xl mb-3 text-brand-teal dark:text-cyan-400">Hôtels de Premier Choix</h3>
          <p class="text-gray-600 dark:text-gray-300">
            Tous nos hôtels sont rigoureusement sélectionnés pour leur propreté, leur confort et leur distance de marche optimale des entrées principales du Haram.
          </p>
        </div>

        <div class="bg-white/95 dark:bg-gray-800 dark:text-white p-8 rounded-2xl shadow-lg">
          <h3 class="font-bold text-xl mb-3 text-brand-teal dark:text-cyan-400">Voyagez en Direct</h3>
          <p class="text-gray-600 dark:text-gray-300">
            L'assurance d'un voyage fluide et sans escale de l'Aéroport Oujda Angads vers Djeddah ou Médine, idéal pour les pèlerins âgés et les familles.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Form Section -->
  <section class="py-16 bg-white dark:bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gray-50 dark:bg-gray-800 rounded-3xl p-8 md:p-12 shadow-2xl border border-gray-100 dark:border-gray-700">
        <h2 class="text-3xl font-bold text-center text-brand-teal mb-4 dark:text-cyan-400">
          Demandez votre Devis Omra Personnalisé
        </h2>
        <p class="text-center text-gray-600 mb-8 dark:text-gray-300">
          Remplissez le formulaire ci-dessous et recevez une offre sur mesure pour votre pèlerinage.
        </p>

        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Nom Complet</label>
              <input 
                type="text" 
                placeholder="Ex: Mohamed Alami"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-brand-teal"
                required
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Téléphone (WhatsApp de préférence)</label>
              <input 
                type="tel" 
                placeholder="Ex: +212 661 234567"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-brand-teal"
                required
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Formule Souhaitée</label>
              <select class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-brand-teal">
                <option value="ramadan">Omra Ramadan</option>
                <option value="direct">Omra Vol Direct (Standard)</option>
                <option value="premium">Omra Premium (Hôtels 5*)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Nombre de personnes</label>
              <input 
                type="number" 
                min="1" 
                value="1"
                class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-brand-teal"
                required
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Message ou demandes particulières</label>
            <textarea 
              rows="4" 
              placeholder="Spécifiez vos besoins (ex: type de chambre, dates souhaitées, etc.)"
              class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-brand-teal"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full bg-gold hover:bg-yellow-600 text-gray-900 font-bold py-4 rounded-xl transition-all duration-300 hover:shadow-lg text-lg uppercase tracking-wider"
          >
            Envoyer la Demande
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
