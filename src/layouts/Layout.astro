---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'fr' | 'ar';
  schemaMarkup?: Record<string, any> | Record<string, any>[];
}

const { 
  title, 
  description = "Beauséjour Voyage - Agence de voyage à Oujda spécialisée dans l'Omra (عمرة وجدة) et Hajj. Vols directs, hébergements proches du Haram et accompagnement de qualité.", 
  lang = 'fr', 
  schemaMarkup 
} = Astro.props;

const isRtl = lang === 'ar';
const dir = isRtl ? 'rtl' : 'ltr';

// Get current URLs for canonical and alternates
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const pathname = Astro.url.pathname;
let alternateFr = '';
let alternateAr = '';

if (pathname.startsWith('/ar')) {
  alternateFr = new URL(pathname.replace(/^\/ar/, '') || '/', Astro.site).href;
  alternateAr = canonicalUrl;
} else {
  alternateFr = canonicalUrl;
  alternateAr = new URL('/ar' + (pathname === '/' ? '' : pathname), Astro.site).href;
}

// Combine schema markups
const baseLocalBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Beauséjour Voyage",
  "image": "https://beausejourvoyage.com/favicon.svg",
  "@id": "https://beausejourvoyage.com/#localbusiness",
  "url": "https://beausejourvoyage.com",
  "telephone": "+212699922229",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Immeuble Essaada, Rue Farhat Hachad",
    "addressLocality": "Oujda",
    "postalCode": "60000",
    "addressCountry": "MA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 34.6867,
    "longitude": -1.9114
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "18:30"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "13:00"
    }
  ],
  "sameAs": [
    "https://www.facebook.com/beausejourvoyage"
  ]
};

const baseTravelAgencySchema = {
  "@context": "https://schema.org",
  "@type": "TravelAgency",
  "name": "Beauséjour Voyage",
  "url": "https://beausejourvoyage.com",
  "logo": "https://beausejourvoyage.com/favicon.svg",
  "telephone": "+212699922229",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Immeuble Essaada, Rue Farhat Hachad",
    "addressLocality": "Oujda",
    "addressCountry": "MA"
  },
  "founder": {
    "@type": "Person",
    "name": "Brahim Fatmi",
    "alternateName": "ابراهيم فاطمي",
    "jobTitle": "Fondateur & CEO / Founder & CEO"
  },
  "employee": [
    {
      "@type": "Person",
      "name": "Brahim Fatmi",
      "alternateName": "ابراهيم فاطمي",
      "jobTitle": "Fondateur & CEO / Founder & CEO"
    },
    {
      "@type": "Person",
      "name": "Moussab Fatmi",
      "alternateName": "مصعب فاطمي",
      "jobTitle": "Directeur du Support Technique / Technical Support Director",
      "url": "https://moussab.com",
      "image": "https://moussab.com/profile.jpg",
      "sameAs": [
        "https://moussab.com"
      ],
      "description": "Responsable du support technique et informatique chez Beausejour Voyage (وجدة). Il supervise l'infrastructure technique, le développement des plateformes numériques de réservation et l'assistance technique générale."
    }
  ]
};

const schemas = [baseLocalBusinessSchema, baseTravelAgencySchema];
if (schemaMarkup) {
  if (Array.isArray(schemaMarkup)) {
    schemas.push(...schemaMarkup);
  } else {
    schemas.push(schemaMarkup);
  }
}
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400;1,700&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- SEO Alternates (hreflang) -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr" href={alternateFr} />
    <link rel="alternate" hreflang="ar" href={alternateAr} />
    <link rel="alternate" hreflang="x-default" href={alternateFr} />

    <title>{title}</title>
    
    {schemas.map((schema) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class={isRtl ? "arabic-text" : ""}>
    <Header lang={lang} />
    <main class="min-h-screen">
      <slot />
    </main>
    <Footer lang={lang} />
    
    <!-- Floating WhatsApp Button -->
    <a
      href="https://wa.me/212699922229"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:bg-[#20ba5a] hover:scale-110 transition-all duration-300 flex items-center justify-center group"
      aria-label="Contact us on WhatsApp"
    >
      <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.394 9.806-9.799.002-2.618-1.01-5.078-2.854-6.924C16.379 2.036 13.91 1.017 11.29 1.017c-5.4.001-9.799 4.403-9.801 9.809-.001 1.77.475 3.493 1.378 5.017l-.992 3.62 3.717-.975zm11.367-7.384c-.327-.164-1.93-.955-2.229-1.062-.298-.11-.517-.165-.73.165-.213.33-.825 1.062-1.011 1.28-.187.219-.373.245-.7.083-.326-.164-1.38-.508-2.63-1.622-.973-.867-1.629-1.938-1.82-2.265-.19-.328-.02-.504.144-.668.148-.147.327-.38.492-.572.164-.19.219-.328.327-.546.11-.219.056-.411-.027-.573-.082-.164-.73-1.758-1.002-2.414-.265-.64-.53-.55-.73-.56-.189-.01-.408-.012-.627-.012-.22 0-.576.082-.878.411-.3.33-1.15 1.123-1.15 2.738 0 1.614 1.176 3.176 1.34 3.394.164.218 2.31 3.52 5.597 4.937.781.337 1.39.539 1.862.689.784.248 1.497.213 2.06.13.628-.094 1.93-.789 2.2-1.512.272-.723.272-1.343.19-1.472-.08-.129-.297-.212-.624-.376z"/>
      </svg>
    </a>

    <script>
      import Alpine from 'alpinejs';
    
      window.Alpine = Alpine;
    
      Alpine.start();
    </script>
  </body>
</html>

<script is:inline>
  // On page load or when changing themes, best to add inline in `head` to avoid FOUC
  if (
    localStorage.getItem('color-theme') === 'dark' ||
    (!('color-theme' in localStorage) &&
      window.matchMedia('(prefers-color-scheme: dark)').matches)
  ) {
    document.documentElement.classList.add('dark');
  } else {
    document.documentElement.classList.remove('dark');
  }

  function setupThemeToggle(toggleId, darkIconId, lightIconId) {
    const themeToggleBtn = document.getElementById(toggleId);
    if (!themeToggleBtn) return;

    const themeToggleDarkIcon = document.getElementById(darkIconId);
    const themeToggleLightIcon = document.getElementById(lightIconId);

    // Change the icons inside the button based on previous settings
    if (
      localStorage.getItem('color-theme') === 'dark' ||
      (!('color-theme' in localStorage) &&
        window.matchMedia('(prefers-color-scheme: dark)').matches)
    ) {
      themeToggleLightIcon.classList.remove('hidden');
    } else {
      themeToggleDarkIcon.classList.remove('hidden');
    }

    themeToggleBtn.addEventListener('click', function () {
      // toggle icons inside button
      themeToggleDarkIcon.classList.toggle('hidden');
      themeToggleLightIcon.classList.toggle('hidden');

      // if set via local storage previously
      if (localStorage.getItem('color-theme')) {
        if (localStorage.getItem('color-theme') === 'light') {
          document.documentElement.classList.add('dark');
          localStorage.setItem('color-theme', 'dark');
        } else {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('color-theme', 'light');
        }

        // if NOT set via local storage previously
      } else {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('color-theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('color-theme', 'dark');
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    setupThemeToggle('theme-toggle', 'theme-toggle-dark-icon', 'theme-toggle-light-icon');
    setupThemeToggle('mobile-theme-toggle', 'mobile-theme-toggle-dark-icon', 'mobile-theme-toggle-light-icon');
  });
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  
  body {
    font-family: 'Inter', system-ui, sans-serif;
  }
  
  .arabic-text {
    font-family: 'Amiri', serif;
    direction: rtl;
  }
</style>