---

<header class="bg-white shadow-lg sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex items-center space-x-3">
        <div class="w-12 h-12 bg-gradient-to-br from-gold to-deep-green rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-xl">BV</span>
        </div>
        <div>
          <h1 class="text-2xl font-bold text-deep-green">Beauséjour Voyage</h1>
          <p class="text-sm text-gray-600">Votre partenaire voyage</p>
        </div>
      </div>

      <!-- Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        <a href="/" class="text-gray-700 hover:text-gold transition-colors duration-200 font-medium">Accueil</a>
        <a href="/hajj-omra" class="text-gray-700 hover:text-gold transition-colors duration-200 font-medium">Hajj & Omra</a>
        <a href="/voyages-organises" class="text-gray-700 hover:text-gold transition-colors duration-200 font-medium">Voyages Organisés</a>
        <a href="/blog" class="text-gray-700 hover:text-gold transition-colors duration-200 font-medium">Blog</a>
        <a href="/contact" class="bg-gold hover:bg-yellow-600 text-white px-6 py-2 rounded-lg transition-colors duration-200 font-medium">
          Contact
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button class="text-gray-700 hover:text-gold">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>