---
---
<section class="py-20 bg-warm-beige dark:bg-gray-900 overflow-hidden transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Title Section -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-brand-teal/10 text-brand-teal dark:bg-cyan-500/10 dark:text-cyan-400 mb-4 tracking-wider uppercase">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm3 2h6v4H7V5zm8 8v2h-2v-2h2zm-2-2h2V9h-2v2zm-2 2h2v-2h-2v2zm-2-2h2V9H9v2zm-2 2h2v-2H7v2zm-2-2h2V9H5v2zm0 2h2v-2H5v2z" clip-rule="evenodd"></path>
        </svg>
        Présentation Officielle • العرض الرسمي
      </span>
      
      <h2 class="text-3xl lg:text-5xl font-black tracking-tight text-gray-900 dark:text-white mb-4">
        Découvrez <span class="bg-gradient-to-r from-brand-teal to-brand-cyan bg-clip-text text-transparent dark:from-cyan-400 dark:to-teal-300">Beau Séjour Voyage</span> en Vidéo
      </h2>
      <h3 class="text-2xl lg:text-3xl font-arabic font-bold text-gold dark:text-yellow-500 arabic-text mt-2">
        اكتشفوا وكالة بوسيجور بالڤيديو
      </h3>
      <div class="w-24 h-1 bg-gradient-to-r from-brand-teal to-gold mx-auto mt-6 rounded-full"></div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Left: Interactive Video Player (7 Cols) -->
      <div class="lg:col-span-7 relative group">
        <!-- Decorative background glow -->
        <div class="absolute -inset-2 bg-gradient-to-tr from-brand-teal to-gold rounded-[2rem] opacity-30 blur-2xl group-hover:opacity-40 transition-all duration-700"></div>
        
        <!-- Video Frame -->
        <div class="relative bg-gradient-to-tr from-brand-teal via-white to-gold dark:via-gray-800 p-1.5 rounded-[2rem] shadow-2xl transform hover:scale-[1.01] transition-all duration-500">
          <div class="relative overflow-hidden rounded-[1.8rem] aspect-video bg-black" x-data="{ muted: true }">
            
            <video
              id="agency-promo-video"
              class="w-full h-full object-cover"
              autoplay
              loop
              playsinline
              controls
              :muted="muted"
              src="/videos/agency-video.mp4"
            >
              Your browser does not support the video tag.
            </video>

            <!-- Custom Unmute floating badge (only when muted is true) -->
            <button 
              @click="muted = !muted" 
              class="absolute bottom-4 right-4 z-20 bg-black/75 hover:bg-black/90 text-white px-4 py-2.5 rounded-full flex items-center gap-2.5 text-xs font-bold backdrop-blur-md transition-all duration-300 border border-white/10 shadow-lg cursor-pointer animate-bounce"
            >
              <!-- Speaker Off Icon (Muted) -->
              <span x-show="muted" class="flex items-center gap-2">
                <span class="relative flex h-2.5 w-2.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-cyan opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-brand-cyan"></span>
                </span>
                <svg class="w-4 h-4 text-brand-cyan" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 9.75L19.5 12m0 0l2.25 2.25M19.5 12l2.25-2.25M19.5 12l-2.25 2.25m-10.5-6L4.5 9H1.5v6h3l4.5 3.75V5.25z" />
                </svg>
                <span class="tracking-wide">ACTIVER LE SON • تشغيل الصوت</span>
              </span>

              <!-- Speaker On Icon (Unmuted) -->
              <span x-show="!muted" class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
                </svg>
                <span class="tracking-wide text-green-400">COUPE LE SON • كتم الصوت</span>
              </span>
            </button>
          </div>
        </div>
      </div>

      <!-- Right: Detailed Info & CTA (5 Cols) -->
      <div class="lg:col-span-5 flex flex-col justify-center space-y-8">
        
        <!-- Text Card in French -->
        <div class="space-y-4">
          <h4 class="text-xl font-bold text-brand-teal dark:text-cyan-400 flex items-center gap-2">
            <span class="w-6 h-0.5 bg-brand-teal dark:bg-cyan-400"></span>
            Votre voyage commence ici
          </h4>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-lg">
            Chez <strong class="text-gray-900 dark:text-white font-semibold">Beau Séjour Voyage</strong>, nous transformons vos rêves de voyage en réalité. Que ce soit pour accomplir vos obligations spirituelles du Hajj et de l'Omra, ou pour explorer de magnifiques destinations à travers le monde, nous vous garantissons un accompagnement professionnel et un confort inégalé.
          </p>
        </div>

        <!-- Text Card in Arabic -->
        <div class="space-y-4 text-right arabic-text">
          <h4 class="text-2xl font-arabic font-bold text-gold dark:text-yellow-500 flex items-center justify-end gap-2">
            رحلتكم تبدأ معنا
            <span class="w-6 h-0.5 bg-gold dark:bg-yellow-500"></span>
          </h4>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed font-arabic text-lg lg:text-xl">
            في وكالة <strong class="text-gray-900 dark:text-white font-bold font-arabic">بو سيجور للاسفار</strong>، نحرص على تقديم أفضل الخدمات لتسهيل رحلاتكم الروحانية لأداء مناسك الحج والعمرة، بالإضافة إلى تنظيم رحلات سياحية مميزة لمختلف الوجهات العالمية بأعلى معايير الجودة والراحة.
          </p>
        </div>

        <!-- Call to Actions -->
        <div class="pt-4 flex flex-col sm:flex-row gap-4 justify-start">
          <a 
            href="/contact" 
            class="inline-flex justify-center items-center px-8 py-4 text-base font-bold text-white bg-gradient-to-r from-brand-teal to-brand-cyan hover:opacity-95 shadow-lg rounded-xl transition-all duration-300 transform hover:-translate-y-0.5"
          >
            Planifier un Voyage • خطط لرحلتك
            <svg class="w-4.5 h-4.5 ml-2 rtl:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

      </div>

    </div>

  </div>
</section>
