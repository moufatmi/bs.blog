---
import { Image } from 'astro:assets';
import logo from '../assets/files/logo1.svg';

interface Props {
  lang?: 'fr' | 'ar';
}

const { lang = 'fr' } = Astro.props;

const t = {
  fr: {
    description: "Spécialiste des voyages religieux (Hajj, Omra) et des voyages organisés. Nous vous accompagnons dans vos plus beaux voyages avec professionnalisme et dévouement.",
    servicesTitle: "Nos Services",
    omra: "Omra Oujda",
    hajjOmra: "Hajj",
    voyages: "Voyages Organisés",
    booking: "Réservations",
    guides: "Guides Spirituels",
    contactTitle: "Contact",
    address: "Immeuble Essaada, Rue Farhat Hachad, Oujda",
    copyright: "Tous droits réservés.",
    omraLink: "/omra",
    hajjOmraLink: "/hajj-omra",
    voyagesLink: "/voyages-organises",
    guidesLink: "/guides",
    contactLink: "/contact",
  },
  ar: {
    description: "متخصصون في الرحلات الدينية (الحج والعمرة) والرحلات المنظمة. نرافقكم في أفضل رحلاتكم بمهنية وتفانٍ.",
    servicesTitle: "خدماتنا",
    omra: "عمرة وجدة",
    hajjOmra: "الحج والعمرة",
    voyages: "رحلات منظمة",
    booking: "حجوزات",
    guides: "مرشدون دينيون",
    contactTitle: "اتصل بنا",
    address: "عمارة السعادة، شارع فرحات حشاد، وجدة",
    copyright: "جميع الحقوق محفوظة.",
    omraLink: "/ar/omra",
    hajjOmraLink: "/hajj-omra",
    voyagesLink: "/voyages-organises",
    guidesLink: "/guides",
    contactLink: "/contact",
  }
}[lang];
---

<footer class="bg-gradient-to-r from-gray-900 via-black to-gold text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center space-x-3 mb-4">
          <Image src={logo} alt="Beauséjour Voyage Logo" width={40} height={40} class="w-10 h-10" />
          <span class="text-xl font-bold text-white">Beauséjour Voyage</span>
        </div>
        <p class="text-gray-200 mb-4 max-w-md">
          {t.description}
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">{t.servicesTitle}</h4>
        <ul class="space-y-2 text-gray-200">
          <li><a href={t.omraLink} class="hover:text-white transition-colors">{t.omra}</a></li>
          <li><a href={t.hajjOmraLink} class="hover:text-white transition-colors">{t.hajjOmra}</a></li>
          <li><a href={t.voyagesLink} class="hover:text-white transition-colors">{t.voyages}</a></li>
          <li><a href="https://ticket.beausejourvoyage.com" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">{t.booking}</a></li>
          <li><a href={t.guidesLink} class="hover:text-white transition-colors">{t.guides}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">{t.contactTitle}</h4>
        <div class="space-y-2 text-gray-200">
          <p class="flex items-center">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
            </svg>
            contact@beausejourvoyage.com
          </p>
          <p class="flex items-center">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
            </svg>
            {t.address}
          </p>
          <p class="flex items-center">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
            </svg>
            +212 6 99 92 22 29
          </p>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-600 mt-8 pt-8 text-center text-gray-200">
      <p>&copy; 2026 Beauséjour Voyage. {t.copyright}</p>
    </div>
  </div>
</footer>