---
export interface Props {
  title: string;
  description: string;
  image: string;
  price: string;
  duration: string;
  features: string[];
  type: 'hajj' | 'omra' | 'voyage';
}

const { title, description, image, price, duration, features, type } = Astro.props;

const typeLabels = {
  hajj: 'Hajj',
  omra: 'Omra',
  voyage: 'Voyage'
};

const typeColors = {
  hajj: 'bg-red-500 text-white',
  omra: 'bg-blue-500 text-white',
  voyage: 'bg-green-500 text-white'
};
---

<div class="bg-white rounded-2xl shadow-lg overflow-hidden flex flex-col group transition-all duration-300 hover:shadow-2xl hover:-translate-y-2 h-full">
  <div class="relative">
    <img src={image} alt={`Image for ${title}`} class="w-full h-56 object-cover" />
    <div class="absolute top-4 right-4 bg-white/90 text-gray-800 px-3 py-1 rounded-full text-sm font-semibold">
      {duration}
    </div>
     <div class="absolute top-4 left-4">
      <span class={`px-3 py-1 rounded-full text-sm font-semibold ${typeColors[type]}`}>
        {typeLabels[type]}
      </span>
    </div>
  </div>

  <div class="p-6 flex-grow flex flex-col">
    <h3 class="text-2xl font-bold text-brand-teal mb-3">{title}</h3>
    <p class="text-gray-600 mb-6 flex-grow">{description}</p>
    
    <div>
      <h4 class="font-bold text-gray-800 mb-3">Inclus dans ce programme :</h4>
      <ul class="space-y-2 text-gray-600">
        {features.slice(0, 5).map(feature => (
          <li class="flex items-center">
            <svg class="w-5 h-5 text-gold mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="p-6 bg-gray-50 border-t mt-auto">
    <div class="flex justify-between items-center">
      <div class="text-2xl font-bold text-brand-teal">
        {price}
      </div>
       <a href="/contact" class="bg-brand-teal hover:opacity-90 text-white font-bold py-2 px-6 rounded-lg transition-all duration-300">
        Contactez-nous
      </a>
    </div>
  </div>
</div>