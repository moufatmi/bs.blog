---
import { Image } from 'astro:assets';
import slider1 from "../assets/sliders/1.png";
import slider2 from "../assets/sliders/2.png";

export interface Props {
    img?: any;
    title?: string;
    desc?: string;
}

const { img, title, desc } = Astro.props;
const isSlider = !img;
---
<section
  x-data={`{
    isSlider: ${isSlider},
    slideIndex: 0,
    slidesCount: 2
  }`}
  x-init="() => {
    if (isSlider) {
        setInterval(() => {
            slideIndex = (slideIndex + 1) % slidesCount;
        }, 7000);
    }
  }"
  class="relative aspect-[9/16] w-full md:aspect-auto md:h-[70vh] lg:h-[85vh] overflow-hidden bg-white"
>
    {isSlider ? (
        <!-- Slider for Homepage -->
        <div class="absolute inset-0 w-full h-full">
            <div
                class="absolute inset-0 transition-opacity duration-1000"
                x-show="slideIndex === 0"
                x-bind:class="{'opacity-100': slideIndex === 0, 'opacity-0': slideIndex !== 0}"
            >
                <Image
                    src={slider1}
                    alt="Agence de voyage Beauséjour Voyage Omra Oujda - Haram Makkah"
                    class="w-full h-full object-contain object-center"
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
            <div
                class="absolute inset-0 transition-opacity duration-1000"
                style="display: none;"
                x-show="slideIndex === 1"
                x-bind:class="{'opacity-100': slideIndex === 1, 'opacity-0': slideIndex !== 1}"
            >
                <Image
                    src={slider2}
                    alt="Agence de voyage Beauséjour Voyage Omra Oujda - Masjid Nabawi"
                    class="w-full h-full object-contain object-center"
                    loading="lazy"
                />
            </div>
        </div>
    ) : (
        <!-- Static Image for other pages -->
        <div class="absolute inset-0">
            <Image
                src={img}
                alt={title ?? 'Agence de voyage Beauséjour Voyage Omra Oujda'}
                class="w-full h-full object-contain object-center"
                loading="eager"
                fetchpriority="high"
            />
        </div>
    )}

    <!-- Overlay (only if text is present) -->
    {title && <div class="absolute inset-0 bg-black/40"></div>}

    <!-- Text Content -->
    {title && (
        <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4 w-full">
            <div class="max-w-3xl mx-4">
                <h1 class="text-2xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-3 text-white leading-tight text-shadow">
                  {title}
                </h1>
                {desc && (
                    <p class="text-xs md:text-sm lg:text-base max-w-2xl mx-auto text-gray-200 leading-relaxed text-shadow-md">
                      {desc}
                    </p>
                )}
            </div>
        </div>
    )}

    <!-- Navigation Dots for slider -->
    <div x-show="isSlider" class="absolute bottom-5 z-20 w-full flex justify-center items-center space-x-3">
        <button
            @click="slideIndex = 0"
            class="w-3 h-3 rounded-full transition"
            x-bind:class="{'bg-white': slideIndex === 0, 'bg-white/50 hover:bg-white': slideIndex !== 0}"
        ></button>
        <button
            @click="slideIndex = 1"
            class="w-3 h-3 rounded-full transition"
            x-bind:class="{'bg-white': slideIndex === 1, 'bg-white/50 hover:bg-white': slideIndex !== 1}"
        ></button>
    </div>
</section>

<style>
.text-shadow {
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.7);
}
.text-shadow-md {
    text-shadow: 1px 1px 6px rgba(0, 0, 0, 0.7);
}
</style>